# Generated theorem registries and debug output
/thmlookup.*.registry.tsv
/thmlookup.*.debug.log
/registry/*
!/registry/.gitkeep

# Generated, content-addressed predecessor cache and publication staging
/registry-cache/
/.registry-cache-stage-*/
/.registry-cache-backup-*/
/.registry-cache-original/
/.registry-cache-layout-test/
/registry-cache-*.tar
/registry-cache-*.tar.gz
/registry-cache-*.zip
